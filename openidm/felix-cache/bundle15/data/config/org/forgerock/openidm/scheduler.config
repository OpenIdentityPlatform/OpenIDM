:org.apache.felix.configadmin.revision:=L"1"
felix.fileinstall.filename="file:/home/runner/work/OpenIDM/OpenIDM/openidm/conf/scheduler.json"
jsonconfig="{\n\ \ \ \ \"threadPool\"\ :\ {\n\ \ \ \ \ \ \ \ \"threadCount\"\ :\ \"10\"\n\ \ \ \ },\n\ \ \ \ \"scheduler\"\ :\ {\n\ \ \ \ \ \ \ \ \"executePersistentSchedules\"\ :\ \"&{openidm.scheduler.execute.persistent.schedules}\"\n\ \ \ \ }\n}"
service.pid="org.forgerock.openidm.scheduler"
